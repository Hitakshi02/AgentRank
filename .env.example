# Copy this file to .env and fill in your real values.
# .env is gitignored - never commit real keys.

# --- Hedera testnet credentials ---
# From portal.hedera.com - the OPERATOR account pays transaction fees
# and acts as "AgentRanker" / the requester in the payment flow.
HEDERA_OPERATOR_ID=0.0.XXXXXX
HEDERA_OPERATOR_KEY=302e0201...

# The AGENT account receives payments (your "GraphRAG Evaluator" agent).
HEDERA_AGENT_ACCOUNT_ID=0.0.YYYYYY

# HCS topic for the audit trail log. Leave blank on first run -
# scripts/setup_hedera.py will create one and print it here.
HEDERA_HCS_TOPIC_ID=

# --- Integration toggles ---
USE_LIVE_HEDERA=false
USE_LIVE_BIGQUERY=false
USE_LIVE_RAGAS=false

TRUST_THRESHOLD=0.5
QUERY_FEE_USD=0.01
